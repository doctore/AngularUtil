    "@angular/router": "21.0.5",
    "lodash": "4.17.21",
    "rxjs": "7.8.1",
    "tslib": "2.5.0"
  },
  "devDependencies": {
    "@angular/build": "21.0.3",
    "@angular/cli": "21.0.3",
    "@angular/compiler-cli": "21.0.5",
    "@types/lodash": "4.17.21",
    "jsdom": "27.3.0",
